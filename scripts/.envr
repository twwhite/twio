### === MANDATORY VALUES ===
## Domain name used with TWIO ecosystem. e.g. apps.domain.example, notes.domain.example, etc.
DOMAIN=timwhite.io
## Base directory for installation/operation of TWIO ecosystem
# Note: Absolute or Relative. Omit trailing forward-slashes "/" as shown in example below
ROOT_DIR=/twio
## If you have a data directory outside of the base directory, establish it here
DATA_DIR=${ROOT_DIR}/tim
## Default email for SSL registration
DEFAULT_SSL_EMAIL=tim@timwhite.io
### === END MANDATORY VALUES ===
### === USER DATA & CUSTOMIZATION ===
## PicoCMS data directory
PICO_DATA_DIR=${DATA_DIR}/files/Apps/pico/
## BORG Backup directory
BORG_BACKUP_FOLDER=${ROOT_DIR}/backups
## PicoCMS composer repository
PICO_COMPOSER_REPOSITORY=https://github.com/picocms/pico-composer
## Homer data directory
HOMER_DATA_DIR=${DATA_DIR}/files/Apps/homer/
#DOKUWIKI_DATA_DIR=
DOKUWIKI_DATA_DIR=${DATA_DIR}/files/Apps/dokuwiki/data
DOKUWIKI_CONFIG_DIR=${DATA_DIR}/files/Apps/dokuwiki/config
## FreshRSS directories
FRESHRSS_DATA_DIR=${DATA_DIR}/freshrss/data/
FRESHRSS_EXTENSIONS_DIR=${DATA_DIR}/freshrss/extensions/
### === END USER DATA & CUSTOMIZATION ===

